{"nodes": [{"id": "2026-05-12-youna-romantic-website-design_youna_website", "label": "Youna Romantic Website", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-12-youna-romantic-website-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A deeply emotional, mobile-first, single-page React website for Youna \u2014 a digital memory box accessed via QR code. Design decisions reinforce warmth, nostalgia, love, and intimacy."}, {"id": "2026-05-12-youna-romantic-website-design_cinematic_scrapbook", "label": "Cinematic Scrapbook Experience", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-12-youna-romantic-website-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Core metaphor: a scrapbook / journal intime that comes alive through scroll and touch. Like someone poured their heart into an interactive world."}, {"id": "2026-05-12-youna-romantic-website-design_approach_c", "label": "Vertical Scroll + Horizontal Galleries Architecture", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-12-youna-romantic-website-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Single-page vertical scroll with horizontal swipe galleries for timeline and polaroids. Fullscreen overlays for Open When portals and Map. Music persists via React Context."}, {"id": "2026-05-12-youna-romantic-website-design_open_when", "label": "Open When Hub & Portals", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-12-youna-romantic-website-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Auto-generated emotional experiences from JSON data. 8 scenarios mapped to emotional states, each with themed ambient backgrounds. Fullscreen overlay triggered from a 2x4 grid hub."}, {"id": "2026-05-12-youna-romantic-website-design_music_context", "label": "MusicContext / MusicProvider", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-12-youna-romantic-website-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "React Context that persists audio state across all sections. Handles autoplay policy (fade-in on first user interaction), volume transitions, and graceful fallback when no music file provided."}, {"id": "2026-05-12-youna-romantic-website-design_easter_eggs", "label": "Easter Eggs & Hidden Secrets", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-12-youna-romantic-website-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "6 hidden interactions: star whisper, hidden letter, Konami-like code, floating symbol, time-based message, scroll-past-ending secret. Scattered globally across sections."}, {"id": "2026-05-12-youna-romantic-website-design_timeline_section", "label": "Timeline Section", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-12-youna-romantic-website-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Chronological story of the relationship with 5 dated cards, horizontal swipe navigation, snap-to-center, progress dots, and tap-to-reveal hidden messages."}, {"id": "2026-05-12-youna-romantic-website-design_polaroid_gallery", "label": "Polaroid Memory Gallery", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-12-youna-romantic-website-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tactile, physical-feeling collection of shared memories. Reusable PolaroidCard component with random rotation, tape decoration, soft shadows, long-press hidden messages, and horizontal swipe browsing."}, {"id": "2026-05-12-youna-romantic-website-design_ending_scene", "label": "Ending Scene", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-12-youna-romantic-website-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The emotional climax. Auto-sequence (~30-40s): deep night sky with stars, progressive text reveal, 'merci d'exister' climax, heart animation, and 'revivre cette histoire' restart link."}, {"id": "2026-05-12-youna-romantic-website-design_data_files", "label": "Data Files (timeline, polaroids, openWhen, mapLocations)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-12-youna-romantic-website-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All personal content stored in src/data/*.json and src/data/*.ts files for easy editing without touching components. Separates content from presentation."}], "edges": [{"source": "2026-05-12-youna-romantic-website-design_youna_website", "target": "2026-05-12-youna-romantic-website-design_cinematic_scrapbook", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-05-12-youna-romantic-website-design.md", "source_location": null, "weight": 1.0}, {"source": "2026-05-12-youna-romantic-website-design_youna_website", "target": "2026-05-12-youna-romantic-website-design_approach_c", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-05-12-youna-romantic-website-design.md", "source_location": null, "weight": 1.0}, {"source": "2026-05-12-youna-romantic-website-design_youna_website", "target": "2026-05-12-youna-romantic-website-design_open_when", "relation": 