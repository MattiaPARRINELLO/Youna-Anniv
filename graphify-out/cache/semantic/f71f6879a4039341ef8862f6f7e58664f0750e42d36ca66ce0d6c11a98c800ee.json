{"nodes": [{"id": "2026-05-13-experience-profonde-design_3_layers", "label": "3 Layers of Cinematic Immersion", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-13-experience-profonde-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Transforms Youna's website into a cinematic, sensory, and spatial experience by adding 3 layers: Cinematic Scroll, Reactive Environment, and Spatial Depth. All effects respect prefers-reduced-motion and mobile constraints."}, {"id": "2026-05-13-experience-profonde-design_cinematic_scroll", "label": "Cinematic Scroll (Layer 1)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-13-experience-profonde-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Layer 1 of immersion. Includes 3-level parallax, gold progress bar, cross-fade transitions between sections, dynamic vignette with per-section intensity, and evolving background gradient."}, {"id": "2026-05-13-experience-profonde-design_reactive_environment", "label": "Reactive Environment (Layer 2)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-13-experience-profonde-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Layer 2 of immersion. Directional particles that move opposite to scroll direction, cursor glow on desktop, ambient pulse glow at page bottom, and reactive star field that accelerates on fast scroll."}, {"id": "2026-05-13-experience-profonde-design_spatial_depth", "label": "Spatial Depth (Layer 3)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-13-experience-profonde-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Layer 3 of immersion. 3D tilt cards with mouse/gyroscope, depth-of-field blur on adjacent cards, floating decorative elements (butterflies, hearts, stars) with different depth levels, dynamic shadows tied to tilt angle, and section zoom on viewport entry."}], "edges": [{"source": "2026-05-13-experience-profonde-design_3_layers", "target": "2026-05-12-youna-romantic-website-design_youna_website", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-05-13-experience-profonde-design.md", "source_location": null, "weight": 1.0}, {"source": "2026-05-13-experience-profonde-design_3_layers", "target": "2026-05-13-experience-profonde-design_cinematic_scroll", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-05-13-experience-profonde-design.md", "source_location": null, "weight": 1.0}, {"source": "2026-05-13-experience-profonde-design_3_layers", "target": "2026-05-13-experience-profonde-design_reactive_environment", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-05-13-experience-profonde-design.md", "source_location": null, "weight": 1.0}, {"source": "2026-05-13-experience-profonde-design_3_layers", "target": "2026-05-13-experience-profonde-design_spatial_depth", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-05-13-experience-profonde-design.md", "source_location": null, "weight": 1.0}, {"source": "2026-05-13-experience-profonde-design_cinematic_scroll", "target": "2026-05-12-youna-romantic-website-design_approach_c", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.8, "source_file": "docs/superpowers/specs/2026-05-13-experience-profonde-design.md", "source_location": null, "weight": 1.0}, {"source": "2026-05-13-experience-profonde-design_reactive_envir