{"nodes": [{"id": "2026-05-17-experience-upgrade-design_experience_upgrade", "label": "Experience Upgrade \u201dMoment Fou\u201d", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-17-experience-upgrade-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Major upgrade to the Youna anniversary experience: spectacular cinematic intro in 3 acts, treasure hunt with 5 hidden gems and mini-game, and powerful final climax with personalized stats and animated handwritten letter."}, {"id": "2026-05-17-experience-upgrade-design_cinematic_intro", "label": "3-Act Cinematic Intro", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-17-experience-upgrade-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replaces existing intro with 3-act sequence: Act 1 - L'Arrivee (heartbeat glow, particles), Act 2 - L'Invitation ('pour toi' text with light sweep), Act 3 - Le Portail (circular portal button that explodes into content). ~8 seconds total, no video, CSS/Canvas/Framer Motion only."}, {"id": "2026-05-17-experience-upgrade-design_treasure_hunt", "label": "Treasure Hunt \u2014 5 Gems", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-17-experience-upgrade-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "5 hidden gems scattered across the experience: Gem 1 - Timeline card tap sequence, Gem 2 - Polaroid photo hotspot, Gem 3 - OpenWhen password from golden letters, Gem 4 - Late-night visit detection, Gem 5 - Star catcher mini-game. Tracked in SecretContext with localStorage persistence."}, {"id": "2026-05-17-experience-upgrade-design_secret_context", "label": "SecretContext", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-17-experience-upgrade-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Shared React Context for gem unlocking state across the app. Tracks which gems are found, visited OpenWhen portals, collected golden letters, and total gem count. Persisted in localStorage for multi-visit tracking."}, {"id": "2026-05-17-experience-upgrade-design_star_catcher", "label": "Star Catcher Mini-Game", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-17-experience-upgrade-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "15-second mini-game where stars fall from the top and the user taps them. Target score: 10. Large touch hitboxes for mobile, max 3 stars at a time, replayable. Triggered from EndingScene restart phase."}, {"id": "2026-05-17-experience-upgrade-design_handwritten_letter", "label": "Handwritten Letter", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-17-experience-upgrade-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Animated component that reveals text character by character (~50ms/char), using cursive Caveat font on parchment texture background. Unlocked only when all 5 gems are found. Configurable speed, skippable via tap."}, {"id": "2026-05-17-experience-upgrade-design_climax_final", "label": "Climax Final \u2014 4 Acts", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-17-experience-upgrade-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ending scene restructured into 4 acts: Act 1 - Progressive Reveal (existing, preserved), Act 2 - Emotional Stats (new StatsBilan showing gems found and time spent), Act 3 - Handwritten Letter (conditionally if 5/5 gems), Act 4 - Invitation to Return (restart button + 'find missing secrets' button)."}, {"id": "2026-05-17-experience-upgrade-design_config_json", "label": "config.json", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-17-experience-upgrade-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Central configuration file for user data. Extends existing config with fields: finalLetter (handwritten letter content), passwordWord (treasure hunt password), hotspotPolaroid (image index and coordinates for hidden gem), and secret messages."}], "edges": [{"source": "2026-05-17-experience-upgrade-design_experience_upgrade", "target": "2026-05-12-youna-romantic-website-design_youna_website", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-05-17-experience-upgrade-design.md", "source_location": null, "weight": 1.0}, {"source": "2026-05-17-experience-upgrade-design_experience_upgrade", "target": "2026-05-17-experience-upgrade-design_cinematic_intro", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-05-17-experience-upgrade-design.md", "source_location": null, "weight": 1.0}, {"source": "2026-05-17-experience-upgrade-design_experience_upgrade", "target": "2026-05-17-experience-upgrade-design_treasure_hunt", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-05-17-experience-upgrade-design.md", "source_location": null, "weight": 1.0}, {"source": "2026-05-17-experience-upgrade-design_experience_upgrade", "target": "2026-05-17-experience-upgrade-design_climax_final", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-05-17-experience-upgrade-design.md", "source_location": null, "weight": 1.0}, {"source": "2026-05-17-experi